{
  "_comment": "此為 ~/.claude/settings.json (user-level) 範本。通用 patterns 放這裡，確保 worktree 和子專案 sub-agent 都有權限。",
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(git * && *)",
      "Bash(gh *)",
      "Bash(gh * | *)",
      "Bash(gh * | * | *)",
      "Bash(gh * --input *)",
      "Bash(gh * --input - <<*)",
      "Bash(gh pr create *)",
      "Bash(gh pr create --repo * --title * --body *)",
      "Bash(pnpm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(bash *)",
      "Bash(ls * && *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(echo *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(rm *)",
      "Bash(ln *)",
      "Bash(diff *)",
      "Bash(which *)",
      "Bash(pwd)",
      "Bash(cd *)",
      "Bash(cd * && *)",
      "Bash(cd * && * && *)",
      "Bash(cd * && * && * && *)",
      "Bash(cd * && * | *)",
      "Bash(cd * && * && * | *)",
      "Bash(cat * | python3 *)",
      "Bash(gh * | python3 *)",
      "Bash(for *)",
      "Bash(jq *)",
      "Bash(python3 *)",
      "Bash(python3 -c \":*)",
      "Bash(sort *)",
      "Bash(md5 *)",
      "Bash(md5)",
      "Bash(chmod *)",
      "Bash(GIT_EDITOR=true *)",
      "Bash(/Users/<USERNAME>/work/.claude/skills/*)",
      "Bash(/Users/<USERNAME>/work/.claude/skills/* | *)",
      "Bash(/Users/<USERNAME>/work/<company>-skills/skills/*)",
      "Bash(/Users/<USERNAME>/<workspace>/scripts/post-branch-setup.sh *)",
      "mcp__claude_ai_Atlassian__*",
      "mcp__claude_ai_Slack__*",
      "mcp__claude_ai_Figma__*",
      "Edit",
      "Write",
      "Agent"
    ]
  }
}
