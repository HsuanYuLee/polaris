{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/no-cd-in-bash.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/no-independent-cmd-chaining.sh\""
          },
          {
            "type": "command",
            "if": "Bash(git push*)",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/pre-push-quality-gate.sh\""
          },
          {
            "type": "command",
            "if": "Bash(git*commit*)",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/version-docs-lint-gate.sh\""
          },
          {
            "type": "command",
            "if": "Bash(gh pr create*)",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/pr-base-gate.sh\""
          },
          {
            "type": "command",
            "if": "Bash(gh pr edit*)",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/pr-base-gate.sh\""
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/design-plan-checklist-gate.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/pipeline-artifact-gate.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/checkpoint-carry-forward-fallback.sh\""
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-summary-precompact.sh\""
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/post-compact-context-restore.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/stop-todo-check.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-summary-stop.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git*commit*)",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/version-bump-reminder.sh\""
          },
          {
            "type": "command",
            "if": "Bash(git*merge*)|Bash(git*rebase*)|Bash(git*cherry-pick*)|Bash(git*checkout*)|Bash(git*switch*)|Bash(git*pull*)",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/specs-sidebar-sync.sh\""
          }
        ]
      },
      {
        "matcher": "Bash|Edit|Write|Read|Grep|Glob|Agent|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/consecutive-reads-monitor.sh\""
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/no-file-reread-monitor.sh\""
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/specs-sidebar-sync.sh\""
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/specs-sidebar-sync.sh\""
          }
        ]
      }
    ]
  },
  "permissions": {
    "additionalDirectories": [
      "/tmp"
    ]
  }
}
