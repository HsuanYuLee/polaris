# ============================================
# Workspace .gitignore — whitelist mode
# Default: ignore everything, then explicitly allow workspace files
# ============================================

# Ignore everything
*

# ── Workspace base files (L1) ──
!.gitignore
!.gitmodules
!CLAUDE.md
!README.md
!README.zh-TW.md
!LICENSE
!VERSION
!CHANGELOG.md
!package.json
!pnpm-workspace.yaml
!pnpm-lock.yaml
!AGENTS.md
!workspace-config.yaml.example
!polaris-toolchain.yaml

# ── docs/ documentation ──
!docs/
!docs/**

# ── docs-manager/ specs browser (Starlight app) ──
!docs-manager/
!docs-manager/**
# Generated/runtime docs-manager artifacts
docs-manager/_sidebar.md
docs-manager/.astro/
docs-manager/dist/
docs-manager/public/evidence/
docs-manager/src/content/docs/specs/

# ── scripts/ framework utilities ──
!scripts/
!scripts/**

# ── tools/ framework runtime packages ──
!tools/
!tools/**

# ── _template/ scaffold directory ──
!_template/
!_template/**

# Company directories are local workspace context only.
# They contain company repos, company handbooks, generated scripts, local secrets,
# and Polaris-managed company config. They are read by framework tooling with
# --no-ignore where needed, but must not enter workspace/template tracking.

# ── .claude/ directory (rules, hooks, settings) ──
!.claude/
!.claude/instructions/
!.claude/instructions/**
!.claude/hooks/
!.claude/hooks/**
!.claude/rules/
!.claude/rules/**
!.claude/skills/
!.claude/skills/**
!.claude/handbook/
!.claude/handbook/**
!.claude/settings.json
!.claude/settings.local.json.example
!.claude/settings.local.json.sub-repo-example

# ── CI baseline (DP-032 D12-c) ──
!.github/
!.github/**
!.pre-commit-config.yaml

# ── .agents/ directory (Codex skills compatibility) ──
!.agents/
!.agents/skills
!.agents/skills/**

# ── .codex/ directory (Codex runtime compatibility target) ──
!.codex/
!.codex/**

# ============================================
# Never track (even if manually staged)
# ============================================

# Personal settings
.claude/settings.local.json

# Cross-session active-thread anchor (DP-290) — local session state, not source.
# Written by scripts/update-active-thread.sh, cat'd by the SessionStart hook.
.claude/active-thread.md

# Local-only user workspace surface. This is intentionally peer-level with
# company folders, but it is not a company and is never runtime-discovered.
user/

# Polaris repo-local runtime tools and asset cache.
.polaris/toolchain/
.polaris/toolchain/**
.polaris/runtime/external-writes/
.polaris/runtime/external-writes/**

# Old runtime cache paths. Direct migration only: durable drafts belong in the
# owning ticket or DP source container before closeout.
.codex/external-writes/
.codex/tmp/

# Spec folders — root specs contains design plans and company-scoped ticket specs.
/specs/

# User-specific learning data (scanner delivers via Slack; archive is local dedup only)
.claude/skills/references/learning-queue.md
.claude/skills/references/learning-archive.md

# Root workspace config (company-specific, not for template)
workspace-config.yaml

# Company configs (each company's workspace-config.yaml is local-only)
# /init creates these — they contain company-specific JIRA, GitHub, Slack config
*/workspace-config.yaml

# Company-specific skills (not pushed to template)
# After /init, add your company here: .claude/skills/{company}/
# .claude/skills/acme/

# ── Company polaris-config: workspace-owned local config ──
# Polaris controls these files in the local workspace, but they are
# company/project-specific runtime config and must not enter workspace PRs or
# the Polaris template. Validators read them from disk with --no-ignore.
*/polaris-config/

# Framework tool runtime (node_modules + outputs)
scripts/e2e/node_modules/
scripts/e2e/e2e-results/
scripts/e2e/e2e-results.json
scripts/e2e/test-results/
scripts/mockoon/node_modules/
tools/polaris-toolchain/node_modules/

# System / IDE
.DS_Store
node_modules/
.vite/

# Python bytecode
__pycache__/
*.pyc
