{
  "_doc": [
    "=== Polaris: User-level settings (~/.claude/settings.json) ===",
    "",
    "This file lives at ~/.claude/settings.json and applies to ALL projects.",
    "Sub-agents and worktrees inherit ONLY this file — not project-level settings.",
    "Put your general-purpose patterns here so sub-agents work without prompts.",
    "",
    "Recommended approach:",
    "  - Shell commands (git, gh, pnpm, node, bash) → here (user-level)",
    "  - MCP tools (Atlassian, Slack, Calendar)     → here (user-level)",
    "  - Edit / Write / Agent                       → here (user-level)",
    "  - Project-specific WebFetch domains           → settings.local.json (project)",
    "  - Project-specific Bash scripts               → settings.local.json (project)",
    "",
    "Tip: glob patterns use * (any chars) and ** (any path segments).",
    "  Bash(git *)       matches 'git status', 'git -C /repo log', etc.",
    "  Bash(cd * && *)   matches 'cd /repo && pnpm test' — but prefer tool path",
    "                    parameters over cd (see rules/bash-command-splitting.md)."
  ],
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(gh * | *)",
      "Bash(gh * | * | *)",
      "Bash(gh * --input *)",
      "Bash(gh pr create *)",
      "Bash(pnpm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(bash *)",
      "Bash(python3 *)",
      "Bash(cat * | python3 *)",
      "Bash(gh * | python3 *)",

      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(echo *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(rm *)",
      "Bash(diff *)",
      "Bash(which *)",
      "Bash(pwd)",
      "Bash(jq *)",
      "Bash(sort *)",
      "Bash(chmod *)",
      "Bash(for *)",

      "Bash(/Users/<USERNAME>/work/.claude/skills/*)",
      "Bash(/Users/<USERNAME>/work/.claude/skills/* | *)",

      "mcp__claude_ai_Atlassian__*",
      "mcp__claude_ai_Slack__*",
      "mcp__claude_ai_Figma__*",
      "mcp__claude_ai_Google_Calendar__*",

      "Edit",
      "Write",
      "Agent"
    ]
  }
}
