---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import {
  blockerSummary,
  groupDashboardItems,
  inferStatusDashboard,
  nextCommand,
  primaryLink,
  publicationSummary,
  reportSummary,
  stageLabel,
  statusLabel,
  taskSummary,
  verificationSummary,
  verifyReportLink,
  inferToolchainHealth,
  createTranslator,
  resolveDocsManagerLocale,
} from '../status/index.mjs';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const locale = resolveDocsManagerLocale();
const t = createTranslator(locale);
const dashboard = inferStatusDashboard();
const toolchain = inferToolchainHealth();
const groups = groupDashboardItems(dashboard.items);
const generatedAt = new Date().toISOString();
const sections = [
  { title: t('section.designPlans'), slug: 'design-plans', items: groups.designPlans },
  { title: t('section.companySpecs'), slug: 'company-specs', items: groups.companySpecs },
];
const headings = sections.map((section) => ({
  depth: 2,
  slug: section.slug,
  text: section.title,
}));
---

<StarlightPage
  frontmatter={{
    title: t('page.title'),
    description: t('page.description'),
    lang: locale,
  }}
  headings={headings}
>
  <div class="status-dashboard">
    {
      toolchain.status === 'fail' ? (
        <section class="toolchain-health" aria-labelledby="toolchain-health">
          <h2 id="toolchain-health">{t('toolchain.title')}</h2>
          <p>{t('toolchain.failMessage')}</p>
          <ul>
            {toolchain.failures.map((failure) => (
              <li>
                <strong>{t(`toolchain.check.${failure.id}`)}</strong>: <code>{failure.repair}</code>
              </li>
            ))}
          </ul>
          <p>
            {t('toolchain.repairLabel')}: <code>{toolchain.repairCommand}</code>
          </p>
        </section>
      ) : (
        <section class="toolchain-health ok" aria-labelledby="toolchain-health">
          <h2 id="toolchain-health">{t('toolchain.title')}</h2>
          <p>{t('toolchain.okMessage')}</p>
        </section>
      )
    }
    <section class="toolchain-health" aria-labelledby="nav-sync">
      <h2 id="nav-sync">{t('navSync.title')}</h2>
      <p>{t('navSync.message')}</p>
      <p>
        {t('navSync.reloadLabel')}: <code>{toolchain.navRepairCommand}</code>
      </p>
    </section>

    <p class="dashboard-meta">
      <span>{t('meta.activeItems', { count: dashboard.items.length })}</span>
      <span>{dashboard.specsRoot}</span>
      <span>{generatedAt}</span>
    </p>
    <p><a href={`${base}/`}>{t('nav.quickStart')}</a></p>

    {
      sections.map((section) => (
        <section class="dashboard-section" aria-labelledby={section.slug}>
          <h2 id={section.slug}>{section.title}</h2>
          {section.items.length === 0 ? (
            <div class="empty">{t('empty.noActiveItems')}</div>
          ) : (
            <div class="table-shell">
              <table class="status-table">
                <thead>
                  <tr>
                    <th class="source">{t('table.source')}</th>
                    <th class="title">{t('table.title')}</th>
                    <th class="status">{t('table.status')}</th>
                    <th class="stage">{t('table.stage')}</th>
                    <th class="tasks">{t('table.tasks')}</th>
                    <th class="verification">{t('table.verification')}</th>
                    <th class="report">{t('table.report')}</th>
                    <th class="publication">{t('table.publication')}</th>
                    <th class="blockers">{t('table.blockers')}</th>
                    <th class="next">{t('table.nextCommand')}</th>
                  </tr>
                </thead>
                <tbody>
                  {section.items.map((item) => {
                    const link = primaryLink(item, base);
                    const reportLink = verifyReportLink(item, base);
                    return (
                      <tr>
                        <td class="source">{link ? <a href={link}>{item.id}</a> : item.id}</td>
                        <td class="title">{item.title}</td>
                        <td class="status">
                          <span class={`pill ${item.status}`}>{statusLabel(item.status, locale)}</span>
                        </td>
                        <td class="stage">{stageLabel(item, locale)}</td>
                        <td class="tasks">{taskSummary(item, locale)}</td>
                        <td class="verification">{verificationSummary(item, locale)}</td>
                        <td class="report">
                          {reportLink ? <a href={reportLink}>{reportSummary(item, locale)}</a> : reportSummary(item, locale)}
                        </td>
                        <td class="publication">{publicationSummary(item, locale)}</td>
                        <td class="blockers">{blockerSummary(item)}</td>
                        <td class="next">
                          <code>{nextCommand(item, locale)}</code>
                        </td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            </div>
          )}
        </section>
      ))
    }
  </div>
</StarlightPage>

<style>
  .status-dashboard {
    display: grid;
    gap: 1rem;
    min-width: 0;
  }

  .dashboard-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    color: var(--sl-color-gray-3);
    font-size: var(--sl-text-sm);
    overflow-wrap: anywhere;
  }

  .dashboard-section {
    margin-top: 1.5rem;
    min-width: 0;
  }

  .toolchain-health {
    border: 1px solid var(--sl-color-orange);
    border-radius: 0.375rem;
    padding: 1rem;
    background: var(--sl-color-orange-low);
  }

  .toolchain-health.ok {
    border-color: var(--sl-color-green);
    background: var(--sl-color-green-low);
  }

  .toolchain-health h2 {
    margin-top: 0;
  }

  .toolchain-health p:last-child,
  .toolchain-health ul:last-child {
    margin-bottom: 0;
  }

  .table-shell {
    overflow-x: auto;
    max-width: 100%;
    min-width: 0;
    border: 1px solid var(--sl-color-hairline);
    border-radius: 0.375rem;
    background: var(--sl-color-bg);
  }

  .status-table {
    width: 100%;
    min-width: 88rem;
    border-collapse: collapse;
    table-layout: fixed;
    font-size: var(--sl-text-sm);
  }

  .status-table th,
  .status-table td {
    padding: 0.65rem 0.75rem;
    border-bottom: 1px solid var(--sl-color-hairline);
    text-align: left;
    vertical-align: top;
    line-height: 1.45;
  }

  .status-table th {
    background: var(--sl-color-gray-6);
    color: var(--sl-color-gray-2);
    font-size: var(--sl-text-xs);
    font-weight: 700;
    text-transform: uppercase;
  }

  .status-table tr:last-child td {
    border-bottom: 0;
  }

  .source {
    width: 10rem;
    font-weight: 700;
  }

  .title {
    width: 18rem;
  }

  .status,
  .stage {
    width: 8rem;
  }

  .tasks {
    width: 14rem;
  }

  .verification {
    width: 18rem;
  }

  .report {
    width: 9rem;
  }

  .publication {
    width: 9rem;
  }

  .blockers {
    width: 13rem;
  }

  .next {
    width: 14rem;
  }

  .next code {
    white-space: normal;
    overflow-wrap: anywhere;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    min-height: 1.5rem;
    padding: 0.125rem 0.5rem;
    border: 1px solid var(--sl-color-hairline-light);
    border-radius: 0.25rem;
    background: var(--sl-color-gray-6);
    color: var(--sl-color-gray-2);
    font-size: var(--sl-text-xs);
    font-weight: 700;
  }

  .pill.locked,
  .pill.implemented {
    border-color: var(--sl-color-green);
    background: var(--sl-color-green-low);
    color: var(--sl-color-green-high);
  }

  .pill.seeded,
  .pill.discussion,
  .pill.in_progress,
  .pill.implementing {
    border-color: var(--sl-color-accent);
    background: var(--sl-color-accent-low);
    color: var(--sl-color-accent-high);
  }

  .pill.unknown,
  .pill.blocked,
  .pill.abandoned {
    border-color: var(--sl-color-orange);
    background: var(--sl-color-orange-low);
    color: var(--sl-color-orange-high);
  }

  .empty {
    border: 1px dashed var(--sl-color-hairline-light);
    border-radius: 0.375rem;
    padding: 1rem;
    color: var(--sl-color-gray-3);
    font-size: var(--sl-text-sm);
  }
</style>
