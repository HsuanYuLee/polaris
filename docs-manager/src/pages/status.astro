---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import {
  blockerSummary,
  groupDashboardItems,
  inferStatusDashboard,
  nextCommand,
  primaryLink,
  stageLabel,
  statusLabel,
  taskSummary,
  inferToolchainHealth,
} from '../status/index.mjs';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const dashboard = inferStatusDashboard();
const toolchain = inferToolchainHealth();
const groups = groupDashboardItems(dashboard.items);
const generatedAt = new Date().toISOString();
const sections = [
  { title: 'Design Plans', slug: 'design-plans', items: groups.designPlans },
  { title: 'Company Specs', slug: 'company-specs', items: groups.companySpecs },
];
const headings = sections.map((section) => ({
  depth: 2,
  slug: section.slug,
  text: section.title,
}));
---

<StarlightPage
  frontmatter={{
    title: 'Status Dashboard',
    description: 'Active Polaris specs, design plans, blockers, and suggested next commands.',
  }}
  headings={headings}
>
  <div class="status-dashboard">
    {
      toolchain.status === 'fail' ? (
        <section class="toolchain-health" aria-labelledby="toolchain-health">
          <h2 id="toolchain-health">Toolchain Health</h2>
          <p>Required Polaris runtime tools are missing or incomplete.</p>
          <ul>
            {toolchain.failures.map((failure) => (
              <li>
                <strong>{failure.label}</strong>: <code>{failure.repair}</code>
              </li>
            ))}
          </ul>
          <p>
            Repair: <code>{toolchain.repairCommand}</code>
          </p>
        </section>
      ) : (
        <section class="toolchain-health ok" aria-labelledby="toolchain-health">
          <h2 id="toolchain-health">Toolchain Health</h2>
          <p>Required Polaris runtime tools are installed.</p>
        </section>
      )
    }
    <section class="toolchain-health" aria-labelledby="nav-sync">
      <h2 id="nav-sync">Navigation Sync</h2>
      <p>
        Status Dashboard reads specs at runtime. Sidebar navigation is built by Starlight; reload the
        viewer after adding or moving specs.
      </p>
      <p>
        Reload: <code>{toolchain.navRepairCommand}</code>
      </p>
    </section>

    <p class="dashboard-meta">
      <span>{dashboard.items.length} active items</span>
      <span>{dashboard.specsRoot}</span>
      <span>{generatedAt}</span>
    </p>
    <p><a href={`${base}/`}>Quick Start</a></p>

    {
      sections.map((section) => (
        <section class="dashboard-section" aria-labelledby={section.slug}>
          <h2 id={section.slug}>{section.title}</h2>
          {section.items.length === 0 ? (
            <div class="empty">No active items</div>
          ) : (
            <div class="table-shell">
              <table class="status-table">
                <thead>
                  <tr>
                    <th class="source">Source</th>
                    <th class="title">Title</th>
                    <th class="status">Status</th>
                    <th class="stage">Stage</th>
                    <th class="tasks">Tasks</th>
                    <th class="blockers">Blockers</th>
                    <th class="next">Next Command</th>
                  </tr>
                </thead>
                <tbody>
                  {section.items.map((item) => {
                    const link = primaryLink(item, base);
                    return (
                      <tr>
                        <td class="source">{link ? <a href={link}>{item.id}</a> : item.id}</td>
                        <td class="title">{item.title}</td>
                        <td class="status">
                          <span class={`pill ${item.status}`}>{statusLabel(item.status)}</span>
                        </td>
                        <td class="stage">{stageLabel(item)}</td>
                        <td class="tasks">{taskSummary(item)}</td>
                        <td class="blockers">{blockerSummary(item)}</td>
                        <td class="next">
                          <code>{nextCommand(item)}</code>
                        </td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            </div>
          )}
        </section>
      ))
    }
  </div>
</StarlightPage>

<style>
  :global(html) {
    --sl-content-width: 86rem;
  }

  .status-dashboard {
    display: grid;
    gap: 1rem;
  }

  .dashboard-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    color: var(--sl-color-gray-3);
    font-size: var(--sl-text-sm);
    overflow-wrap: anywhere;
  }

  .dashboard-section {
    margin-top: 1.5rem;
  }

  .toolchain-health {
    border: 1px solid var(--sl-color-orange);
    border-radius: 0.375rem;
    padding: 1rem;
    background: var(--sl-color-orange-low);
  }

  .toolchain-health.ok {
    border-color: var(--sl-color-green);
    background: var(--sl-color-green-low);
  }

  .toolchain-health h2 {
    margin-top: 0;
  }

  .toolchain-health p:last-child,
  .toolchain-health ul:last-child {
    margin-bottom: 0;
  }

  .table-shell {
    overflow-x: auto;
    border: 1px solid var(--sl-color-hairline);
    border-radius: 0.375rem;
    background: var(--sl-color-bg);
  }

  .status-table {
    width: 100%;
    min-width: 62rem;
    border-collapse: collapse;
    table-layout: fixed;
    font-size: var(--sl-text-sm);
  }

  .status-table th,
  .status-table td {
    padding: 0.65rem 0.75rem;
    border-bottom: 1px solid var(--sl-color-hairline);
    text-align: left;
    vertical-align: top;
    line-height: 1.45;
  }

  .status-table th {
    background: var(--sl-color-gray-6);
    color: var(--sl-color-gray-2);
    font-size: var(--sl-text-xs);
    font-weight: 700;
    text-transform: uppercase;
  }

  .status-table tr:last-child td {
    border-bottom: 0;
  }

  .source {
    width: 10rem;
    font-weight: 700;
  }

  .title {
    width: 18rem;
  }

  .status,
  .stage {
    width: 8rem;
  }

  .tasks {
    width: 14rem;
  }

  .blockers {
    width: 13rem;
  }

  .next {
    width: 14rem;
  }

  .next code {
    white-space: normal;
    overflow-wrap: anywhere;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    min-height: 1.5rem;
    padding: 0.125rem 0.5rem;
    border: 1px solid var(--sl-color-hairline-light);
    border-radius: 0.25rem;
    background: var(--sl-color-gray-6);
    color: var(--sl-color-gray-2);
    font-size: var(--sl-text-xs);
    font-weight: 700;
  }

  .pill.locked,
  .pill.implemented {
    border-color: var(--sl-color-green);
    background: var(--sl-color-green-low);
    color: var(--sl-color-green-high);
  }

  .pill.seeded,
  .pill.discussion,
  .pill.in_progress,
  .pill.implementing {
    border-color: var(--sl-color-accent);
    background: var(--sl-color-accent-low);
    color: var(--sl-color-accent-high);
  }

  .pill.unknown,
  .pill.blocked,
  .pill.abandoned {
    border-color: var(--sl-color-orange);
    background: var(--sl-color-orange-low);
    color: var(--sl-color-orange-high);
  }

  .empty {
    border: 1px dashed var(--sl-color-hairline-light);
    border-radius: 0.375rem;
    padding: 1rem;
    color: var(--sl-color-gray-3);
    font-size: var(--sl-text-sm);
  }
</style>
